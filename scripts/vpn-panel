#!/usr/bin/env bash
set -euo pipefail

# Полный PATH: иначе «docker-compose» в /usr/local/bin не виден из systemd/cron.
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

# Корень репозитория: родитель каталога scripts/. При вызове через симлинк
# (/usr/local/bin/vpn-panel) dirname "$0" даёт /usr/local/bin — без readlink
# получится неверный ROOT и git update сломается.
_vpn_panel_resolve_root() {
  local src="${BASH_SOURCE[0]:-$0}"
  local dir link
  while [[ -h "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    link="$(readlink "$src")" || break
    [[ "$link" != /* ]] && link="$dir/$link"
    src="$link"
  done
  cd -P "$(dirname "$src")/.." && pwd
}
ROOT="$(_vpn_panel_resolve_root)"
unset -f _vpn_panel_resolve_root
cd "$ROOT"

# После «git reset --hard» Git может восстановить режим 100644 — без +x будет Permission denied.
ensure_exec_bits() {
  chmod +x \
    "$ROOT/scripts/vpn-panel" \
    "$ROOT/scripts/run-gen-xray-ports.sh" \
    "$ROOT/scripts/issue-tls-cert.sh" \
    2>/dev/null || true
}
ensure_exec_bits

export COMPOSE_FILE="${COMPOSE_FILE:-docker-compose.yml:docker-compose.xray-ports.gen.yml}"

# Сначала отдельная команда «docker-compose» (часто так на VPS с docker.io).
# Иначе — подкоманда «docker compose» (плагин v2). Переопределение: DOCKER_COMPOSE_BIN=/path/to/docker-compose
dc() {
  if [[ -n "${DOCKER_COMPOSE_BIN:-}" ]]; then
    "$DOCKER_COMPOSE_BIN" "$@"
  elif command -v docker-compose >/dev/null 2>&1; then
    docker-compose "$@"
  elif docker compose version >/dev/null 2>&1; then
    docker compose "$@"
  else
    echo "vpn-panel: не найдены «docker-compose» и «docker compose»." >&2
    echo "  Установите: apt-get install -y docker-compose-v2" >&2
    echo "  Или Docker: https://get.docker.com" >&2
    echo "  Свой бинарник: export DOCKER_COMPOSE_BIN=/path/to/docker-compose" >&2
    exit 1
  fi
}

ensure_ports() {
  bash "$ROOT/scripts/run-gen-xray-ports.sh"
}

# Быстрый перезапуск только процесса xray (тот же контейнер), чтобы подтянуть config.json.
# С xray-supervisor.sh: SIGTERM дочернему xray. Старый режим (xray = PID1):
# SIGTERM PID1 ≈ тому же, что и docker restart xray.
xray_process_restart() {
  if ! dc ps -q xray | grep -q .; then
    echo "vpn-panel: контейнер xray не запущен" >&2
    return 1
  fi
  if dc exec -T xray sh -c \
    'if [ -f /var/run/xray-child.pid ]; then
       pid=$(cat /var/run/xray-child.pid 2>/dev/null) || true
       if [ -n "$pid" ] && [ -d "/proc/$pid" ] && kill -TERM "$pid" 2>/dev/null; then exit 0; fi
     fi
     kill -TERM 1' 2>/dev/null; then
    return 0
  fi
  echo "vpn-panel: «xray-restart» через exec не удался, делаю docker restart xray…" >&2
  dc restart xray
}

# Как на типичном сервере: без «локальных» отличий от origin (chmod/правки не блокируют обновление).
sync_repo_from_origin() {
  local branch
  branch="${BRANCH:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)}"
  if [[ -z "$branch" || "$branch" == "HEAD" ]]; then
    branch=main
  fi
  echo "vpn-panel update: fetch + reset к origin/$branch"
  git fetch origin "$branch" || git fetch origin
  if ! git rev-parse --verify -q "refs/remotes/origin/$branch" >/dev/null; then
    echo "vpn-panel update: после fetch нет ветки origin/$branch. Задайте BRANCH=… или переключитесь на ветку с remote." >&2
    exit 1
  fi
  git reset --hard "origin/$branch"
  ensure_exec_bits
}

cmd="${1:-}"
case "$cmd" in
  start)
    ensure_ports
    dc up -d
    ;;
  stop)
    ensure_ports
    dc down
    ;;
  restart)
    ensure_ports
    dc restart
    ;;
  xray-restart)
    xray_process_restart
    ;;
  reload-xray)
    # Как раньше: xray (быстрый путь — xray-restart) + рестарт панели
    xray_process_restart
    dc restart panel
    ;;
  update)
    sync_repo_from_origin
    ensure_ports
    dc up -d --build
    ;;
  xray-status)
    dc ps xray
    ;;
  xray-logs)
    lines="${2:-100}"
    if ! [[ "$lines" =~ ^[0-9]+$ ]] || [[ "$lines" -lt 1 ]]; then
      echo "vpn-panel xray-logs: второй аргумент — число строк (tail), например: vpn-panel xray-logs 200" >&2
      exit 1
    fi
    if [[ "$lines" -gt 10000 ]]; then
      lines=10000
    fi
    dc logs --tail="$lines" xray
    ;;
  issue-tls)
    dom="${2:-}"
    if [[ -z "$dom" ]]; then
      echo "vpn-panel issue-tls: укажите FQDN, например: vpn-panel issue-tls panel.example.com" >&2
      exit 1
    fi
    if [[ "${EUID:-0}" -eq 0 ]]; then
      bash "$ROOT/scripts/issue-tls-cert.sh" "$dom"
    else
      exec sudo bash "$ROOT/scripts/issue-tls-cert.sh" "$dom"
    fi
    ;;
  users-stats)
    if [[ ! -f "$ROOT/.env" ]]; then
      echo "vpn-panel users-stats: нет $ROOT/.env" >&2
      exit 1
    fi
    set -a
    # shellcheck source=/dev/null
    source "$ROOT/.env"
    set +a
    if [[ -z "${POSTGRES_PASSWORD:-}" ]]; then
      echo "vpn-panel users-stats: в .env не задан POSTGRES_PASSWORD" >&2
      exit 1
    fi
    dc exec -T -e "PGPASSWORD=${POSTGRES_PASSWORD}" postgres \
      psql -h 127.0.0.1 -U vpn -d vpn -v ON_ERROR_STOP=1 \
      -c "SELECT COUNT(*) AS total, COUNT(*) FILTER (WHERE enabled) AS enabled FROM users;"
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|xray-restart|reload-xray|update|xray-status|xray-logs [N]|issue-tls <fqdn>|users-stats}" >&2
    exit 1
    ;;
esac
