# API key for X-API-Key header (generated by install.sh)
API_KEY=

# Postgres password (same value embedded in DATABASE_URL for local compose)
POSTGRES_PASSWORD=CHANGE_ME

# PostgreSQL URL for the panel process
DATABASE_URL=postgres://vpn:CHANGE_ME@postgres:5432/vpn

# Xray gRPC API (from panel container: service name "xray")
XRAY_API_HOST=xray
XRAY_API_PORT=10085

# Path to Xray-core clone (proto roots). In Docker: /app/xray-core
XRAY_PROTO_ROOT=/app/xray-core

# Путь к config.json Xray. В Docker (типовой compose): /app/config/xray/config.json (том config/xray).
# Для dev из корня репо по умолчанию: <корень>/config/xray/config.json
# XRAY_CONFIG_PATH=/app/config/xray/config.json

# Перезагрузка Xray через API (POST /xray/reload):
# none | compose | script
# XRAY_RELOAD_TYPE=compose
# Каталог с docker-compose*.yml (в Docker обычно /work, монтирование корня репо)
# XRAY_RELOAD_COMPOSE_DIR=/work
# Список файлов через : (как у COMPOSE_FILE)
# XRAY_RELOAD_COMPOSE_FILE=docker-compose.yml:docker-compose.xray-ports.gen.yml
# Имя стека: как в `docker compose ls` на хосте (у нового .env от install: basename каталога установки)
# COMPOSE_PROJECT_NAME=super-vpn-panel
# script: XRAY_RELOAD_SCRIPT=...  и при mode=withPanel: XRAY_RELOAD_WITH_PANEL_COMMAND=...
# XRAY_RELOAD_SCRIPT=cd /opt/fast-panel && ./scripts/vpn-panel xray-restart
# XRAY_RELOAD_WITH_PANEL_COMMAND=cd /opt/fast-panel && ./scripts/vpn-panel reload-xray

# Panel port (both inside container and exposed on host). Default: 12983.
# With TLS_CERT+TLS_KEY panel speaks HTTPS; without — plain HTTP.
PORT=12983

# TLS certificate paths (set by install.sh via certbot, mounted from /etc/letsencrypt).
# Leave empty to run without TLS (HTTP only).
TLS_CERT=
TLS_KEY=

# Traffic sync interval (ms)
TRAFFIC_SYNC_INTERVAL_MS=60000
