# API key for X-API-Key header (generated by install.sh)
API_KEY=

# Postgres password (same value embedded in DATABASE_URL for local compose)
POSTGRES_PASSWORD=CHANGE_ME

# PostgreSQL URL for the panel process
DATABASE_URL=postgres://vpn:CHANGE_ME@postgres:5432/vpn

# Xray gRPC API (from panel container: service name "xray")
XRAY_API_HOST=xray
XRAY_API_PORT=10085

# Path to Xray-core clone (proto roots). In Docker: /app/xray-core
XRAY_PROTO_ROOT=/app/xray-core

# Опционально: путь к JSON Xray от корня репо (по умолчанию config/xray/config.json).
# Из inbounds[].port генерируется docker-compose.xray-ports.gen.yml (проброс в compose).
# XRAY_CONFIG_PATH=config/xray/config.json

# Panel HTTP port inside container (compose maps 3000:3000)
PORT=3000

# Traffic sync interval (ms)
TRAFFIC_SYNC_INTERVAL_MS=60000
