{
  "name": "super-vpn-panel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "fetch-protos": "node scripts/fetch-protos.mjs",
    "gen:xray-ports": "bash scripts/run-gen-xray-ports.sh"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@grpc/grpc-js": "^1.12.5",
    "@grpc/proto-loader": "^0.7.13",
    "@noble/curves": "^1.8.1",
    "fastify": "^5.2.1",
    "node-pg-migrate": "^7.9.1",
    "postgres": "^3.4.5",
    "protobufjs": "^8.0.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
